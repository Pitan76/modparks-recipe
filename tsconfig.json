{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "types": [
      "@cloudflare/workers-types"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "include": ["src"],
  "comment": "src/client and src/core are the browser-only standalone tool (DOM libs); Vite type-checks them separately.",
  "exclude": ["node_modules", "dist", "src/client", "src/core"]
}
